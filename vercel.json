{
  "functions": {
    "index.php": {
      "runtime": "vercel-php@0.6.2"
    },
    "modules/**/*.php": {
      "runtime": "vercel-php@0.6.2"
    },
    "config/**/*.php": {
      "runtime": "vercel-php@0.6.2"
    },
    "components/**/*.php": {
      "runtime": "vercel-php@0.6.2"
    }
  },
  "routes": [
    {
      "src": "/(.*\\.php)",
      "dest": "/$1"
    },
    {
      "src": "/",
      "dest": "/index.php"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
